generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  sessionId     String?        @unique @map("session_id")
  email         String?        @unique
  emailVerified DateTime?      @map("email_verified")
  name          String?
  image         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  lastActiveAt  DateTime       @default(now()) @map("last_active_at")
  consultations Consultation[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Consultation {
  id                 String             @id @default(uuid())
  userId             String             @map("user_id")
  rawInput           String             @map("raw_input")
  extractedJson      Json?              @map("extracted_json")
  suspectedCondition String?            @map("suspected_condition")
  severityLevel      String?            @map("severity_level")
  confidenceScore    Float?             @map("confidence_score")
  educationOutput    String?            @map("education_output")
  aiModelUsed        String?            @map("ai_model_used")
  responseTimeMs     Int?               @map("response_time_ms")
  followUpCount      Int                @default(0) @map("follow_up_count")
  language           String             @default("id")
  status             String             @default("pending")
  createdAt          DateTime           @default(now()) @map("created_at")
  user               User               @relation(fields: [userId], references: [id])
  odontogramRecords  OdontogramRecord[]
  feedback           Feedback[]
  messages           Message[]

  @@map("consultations")
}

model Message {
  id              String       @id @default(uuid())
  consultationId  String       @map("consultation_id")
  role            String       // "user" | "assistant"
  content         String
  createdAt       DateTime     @default(now()) @map("created_at")
  consultation    Consultation @relation(fields: [consultationId], references: [id])

  @@map("messages")
}

model OdontogramRecord {
  id              String       @id @default(uuid())
  consultationId  String       @map("consultation_id")
  toothNumber     Int          @map("tooth_number")
  conditionLabel  String       @map("condition_label")
  severityLevel   String?      @map("severity_level")
  confidenceScore Float?       @map("confidence_score")
  description     String?
  createdAt       DateTime     @default(now()) @map("created_at")
  consultation    Consultation @relation(fields: [consultationId], references: [id])

  @@map("odontogram_records")
}

model Feedback {
  id              String       @id @default(uuid())
  consultationId  String       @map("consultation_id")
  rating          Int
  comment         String?
  createdAt       DateTime     @default(now()) @map("created_at")
  consultation    Consultation @relation(fields: [consultationId], references: [id])

  @@map("feedback")
}
